---
interface Props {
  isLanding?: boolean;
}

const { isLanding = false } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/signal', label: 'Signal' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 bg-obsidian/95 backdrop-blur-sm border-b border-white/10 transition-all duration-300',
    isLanding ? 'nav-hidden' : 'nav-visible',
  ]}
>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <!-- Wordmark -->
      <a href="/" class="flex items-center group" aria-label="Monovus home">
        <span class="text-electric-cyan font-mono font-bold text-xl tracking-tight group-hover:text-electric-cyan-dark transition-colors">
          monovus
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-electric-cyan'
                : 'text-white/70 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-white/70 hover:text-white p-2"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-2 pt-2 border-t border-white/10">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-electric-cyan bg-white/5'
                : 'text-white/70 hover:text-white hover:bg-white/5',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    hamburger?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // Scroll-reveal navigation for landing page
  const header = document.getElementById('site-header');
  const sentinel = document.getElementById('hero-sentinel');

  if (header && sentinel) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          header.classList.remove('nav-visible');
          header.classList.add('nav-hidden');
        } else {
          header.classList.remove('nav-hidden');
          header.classList.add('nav-visible');
        }
      },
      { threshold: 0 }
    );
    observer.observe(sentinel);
  }
</script>
