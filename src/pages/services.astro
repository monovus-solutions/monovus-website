---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Services"
  description="Technology consulting, AI & automation systems, and infrastructure engineering. Monovus Solutions helps businesses build systems that scale."
>
  <!-- Page Header -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-electric-cyan font-mono text-sm tracking-widest uppercase mb-4">Services</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-6">
          Three disciplines,<br />one mission
        </h1>
        <p class="text-lg text-white/60 leading-relaxed">
          We bring deep expertise across consulting, AI, and infrastructure to solve
          complex technology challenges. Every engagement is tailored to your specific needs.
        </p>
      </div>
    </div>
  </section>

  <!-- Service 1: Technology Consulting -->
  <section class="pb-20" id="consulting">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-obsidian-light border border-white/10 rounded-2xl p-8 sm:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div>
            <div class="w-14 h-14 bg-electric-cyan/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-electric-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white mb-4">Technology Consulting</h2>
            <p class="text-white/60 leading-relaxed mb-6">
              Strategic technology guidance for organizations navigating complex decisions.
              We help you evaluate options, design architectures, and build roadmaps that
              align technology investments with business outcomes.
            </p>
            <p class="text-white/60 leading-relaxed">
              From startup architecture reviews to enterprise modernization strategies,
              we bring hands-on experience and pragmatic thinking to every engagement.
            </p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4">What's included</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Architecture reviews and technical due diligence</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Technology selection and vendor evaluation</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Digital transformation roadmaps</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Security posture assessments</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Cloud migration planning and cost optimization</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Team capability assessments and hiring guidance</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 2: AI & Automation -->
  <section class="pb-20" id="ai-automation">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-obsidian-light border border-white/10 rounded-2xl p-8 sm:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div>
            <div class="w-14 h-14 bg-electric-cyan/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-electric-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white mb-4">AI &amp; Automation Systems</h2>
            <p class="text-white/60 leading-relaxed mb-6">
              Custom AI integrations and workflow automation that eliminate repetitive work
              and unlock new capabilities. We build practical systems that deliver measurable
              results, not science projects.
            </p>
            <p class="text-white/60 leading-relaxed">
              Whether it's integrating LLMs into your workflows, building intelligent
              monitoring, or automating complex business processes, we design systems
              that work reliably at scale.
            </p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4">What's included</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">LLM integration and prompt engineering</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Workflow automation with n8n, Zapier, or custom solutions</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Intelligent alerting and anomaly detection</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Data pipeline design and ETL automation</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Chatbot and conversational AI development</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">AI readiness assessments and strategy</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 3: Infrastructure & DevOps -->
  <section class="pb-20" id="infrastructure">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-obsidian-light border border-white/10 rounded-2xl p-8 sm:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div>
            <div class="w-14 h-14 bg-electric-cyan/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-electric-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white mb-4">Infrastructure &amp; DevOps</h2>
            <p class="text-white/60 leading-relaxed mb-6">
              Resilient infrastructure that deploys fast and recovers faster. We design,
              build, and maintain cloud and hybrid environments with a focus on reliability,
              security, and operational efficiency.
            </p>
            <p class="text-white/60 leading-relaxed">
              From zero-trust networking to automated backup systems, we build the
              foundation that lets your team focus on shipping features instead of
              fighting fires.
            </p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4">What's included</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Cloud architecture (AWS, GCP, Azure, Oracle Cloud)</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">CI/CD pipeline design and implementation</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Container orchestration (Docker, Kubernetes)</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Monitoring, alerting, and observability (Grafana, Prometheus)</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Zero-trust networking and VPN architecture</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-electric-cyan mt-1">▸</span>
                <span class="text-white/60 text-sm">Backup strategy, disaster recovery, and business continuity</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-20 sm:pb-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Not sure where to start?</h2>
      <p class="text-white/50 max-w-xl mx-auto mb-8">
        Reach out for a free initial conversation. We'll help you figure out
        what you need and whether we're the right fit.
      </p>
      <a
        href="/contact"
        class="inline-block bg-electric-cyan text-obsidian px-8 py-3 rounded-lg font-semibold hover:bg-electric-cyan-dark transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
