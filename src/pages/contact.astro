---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch."
>
  <section class="py-20 sm:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-mono text-electric-cyan text-sm tracking-widest uppercase mb-16">Contact</h1>

      <p class="text-white/60 text-lg mb-8">If this resonates, reach out.</p>

      <a
        href="mailto:hello@monovus.solutions"
        class="text-electric-cyan hover:text-electric-cyan-dark font-mono text-lg sm:text-xl transition-colors"
      >
        hello@monovus.solutions
      </a>
    </div>
  </section>
</BaseLayout>
