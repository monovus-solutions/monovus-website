---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service"
  description="Monovus terms of service."
>
  <section class="py-20 sm:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-electric-cyan font-mono text-sm tracking-widest uppercase mb-4">Legal</p>
      <h1 class="text-4xl font-bold text-white mb-12">Terms of Service</h1>

      <div class="prose prose-invert max-w-none space-y-8">
        <div>
          <h2 class="text-xl font-semibold text-white mb-3">Agreement</h2>
          <p class="text-white/60 leading-relaxed">
            By accessing monovus.solutions, you agree to these terms. If you do not
            agree, do not use the site.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-white mb-3">Use of the Site</h2>
          <p class="text-white/60 leading-relaxed">
            You may use this site for lawful purposes only. You agree not to attempt
            unauthorized access to any part of the site or its systems, use automated
            tools to scrape or extract data, or transmit malicious code.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-white mb-3">Intellectual Property</h2>
          <p class="text-white/60 leading-relaxed">
            All content on this site — text, graphics, logos, and design — is the
            property of Monovus. You may not reproduce, distribute, or create derivative
            works without prior written consent.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-white mb-3">Disclaimer</h2>
          <p class="text-white/60 leading-relaxed">
            The site is provided "as is" without warranties of any kind. Monovus does
            not warrant that the site will be uninterrupted, error-free, or free of
            harmful components.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-white mb-3">Limitation of Liability</h2>
          <p class="text-white/60 leading-relaxed">
            Monovus shall not be liable for any indirect, incidental, special, or
            consequential damages arising from your use of the site.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-white mb-3">Changes</h2>
          <p class="text-white/60 leading-relaxed">
            These terms may be modified at any time. Continued use of the site after
            changes constitutes acceptance of the revised terms.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-white mb-3">Contact</h2>
          <p class="text-white/60 leading-relaxed">
            Questions about these terms:
            <a href="mailto:hello@monovus.solutions" class="text-electric-cyan hover:text-electric-cyan-dark">hello@monovus.solutions</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
