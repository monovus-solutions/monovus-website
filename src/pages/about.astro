---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="What Monovus is."
>
  <section class="py-20 sm:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-mono text-electric-cyan text-sm tracking-widest uppercase mb-16">About</h1>

      <p class="text-white/60 text-lg sm:text-xl leading-relaxed">
        Monovus builds systems that operate with intent. We exist at the intersection
        of infrastructure, intelligence, and autonomy — engineering the substrates that
        future systems will run on. Not a consultancy. Not a product company. A quiet,
        deliberate effort to build what comes next.
      </p>
    </div>
  </section>
</BaseLayout>
