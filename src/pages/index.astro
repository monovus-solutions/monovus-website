---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Monovus"
  description="Systems that operate with intent."
  isLanding={true}
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- CSS-only animated gradient background -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse at 20% 50%, rgba(0,242,245,0.07) 0%, transparent 50%), radial-gradient(ellipse at 80% 20%, rgba(0,242,245,0.05) 0%, transparent 50%), radial-gradient(ellipse at 50% 80%, rgba(0,242,245,0.06) 0%, transparent 50%); background-size: 400% 400%; animation: gradient-shift 20s ease infinite;"
    ></div>

    <div class="relative text-center px-6">
      <h1 class="font-mono text-electric-cyan text-4xl sm:text-5xl lg:text-6xl tracking-tight mb-6">
        monovus
      </h1>
      <p class="text-white/50 text-lg sm:text-xl font-light tracking-wide">
        Systems that operate with intent.
      </p>
    </div>

    <!-- Sentinel for IntersectionObserver (header scroll-reveal) -->
    <div id="hero-sentinel" class="absolute bottom-0 left-0 w-full h-px"></div>
  </section>

  <!-- Section 1: Philosophy -->
  <section class="fade-in-section py-24 sm:py-32 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-white/60 text-lg sm:text-xl leading-relaxed">
        We build systems that operate with intent. Not products. Not services.
        Infrastructure for what comes next.
      </p>
    </div>
  </section>

  <!-- Section 2: What Monovus Builds -->
  <section class="fade-in-section py-24 sm:py-32 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-white/40 text-lg sm:text-xl leading-relaxed font-mono">
        Agentic systems. Infrastructure autonomy. Intelligence at the edge.
      </p>
    </div>
  </section>

  <!-- Section 3: Quiet CTA -->
  <section class="fade-in-section py-24 sm:py-32 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-white/40 text-lg sm:text-xl leading-relaxed mb-4">
        Something worth building?
      </p>
      <a
        href="mailto:hello@monovus.solutions"
        class="text-electric-cyan font-mono text-lg hover:text-electric-cyan-dark transition-colors"
      >
        hello@monovus.solutions
      </a>
    </div>
  </section>

  <!-- Scroll fade-in observer -->
  <script>
    const sections = document.querySelectorAll('.fade-in-section');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.15 }
    );
    sections.forEach((section) => observer.observe(section));
  </script>
</BaseLayout>
