---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Monovus Solutions"
  description="Infrastructure. Intelligence. Innovation. Technology consulting, AI systems, and infrastructure automation for the modern enterprise."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-obsidian via-obsidian-light/50 to-obsidian"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-electric-cyan/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
      <div class="max-w-3xl">
        <p class="text-electric-cyan font-mono text-sm tracking-widest uppercase mb-4">
          Infrastructure · Intelligence · Innovation
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Technology that
          <span class="text-electric-cyan">works for you</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/60 leading-relaxed mb-8 max-w-2xl">
          Monovus Solutions delivers expert technology consulting, AI-powered automation,
          and infrastructure engineering. We help businesses build systems that scale,
          stay secure, and run themselves.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="bg-electric-cyan text-obsidian px-8 py-3 rounded-lg font-semibold text-center hover:bg-electric-cyan-dark transition-colors"
          >
            Start a Conversation
          </a>
          <a
            href="/services"
            class="border border-white/20 text-white px-8 py-3 rounded-lg font-semibold text-center hover:border-electric-cyan hover:text-electric-cyan transition-colors"
          >
            View Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">What We Do</h2>
        <p class="text-white/50 max-w-2xl mx-auto">
          Three core disciplines, one unified approach to solving complex technology challenges.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Consulting -->
        <div class="bg-obsidian-light border border-white/10 rounded-xl p-8 hover:border-electric-cyan/30 transition-colors group">
          <div class="w-12 h-12 bg-electric-cyan/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-electric-cyan/20 transition-colors">
            <svg class="w-6 h-6 text-electric-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Technology Consulting</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            Strategic guidance on architecture decisions, technology selection, and digital
            transformation. We help you make the right choices before writing a single line of code.
          </p>
        </div>

        <!-- AI & Automation -->
        <div class="bg-obsidian-light border border-white/10 rounded-xl p-8 hover:border-electric-cyan/30 transition-colors group">
          <div class="w-12 h-12 bg-electric-cyan/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-electric-cyan/20 transition-colors">
            <svg class="w-6 h-6 text-electric-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">AI &amp; Automation Systems</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            Custom AI integrations, workflow automation, and intelligent systems that reduce
            manual effort and unlock new capabilities across your operations.
          </p>
        </div>

        <!-- Infrastructure -->
        <div class="bg-obsidian-light border border-white/10 rounded-xl p-8 hover:border-electric-cyan/30 transition-colors group">
          <div class="w-12 h-12 bg-electric-cyan/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-electric-cyan/20 transition-colors">
            <svg class="w-6 h-6 text-electric-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Infrastructure &amp; DevOps</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            Cloud architecture, CI/CD pipelines, monitoring, and infrastructure automation.
            We build resilient systems that deploy fast and recover faster.
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/services" class="text-electric-cyan hover:text-electric-cyan-dark font-medium transition-colors">
          Learn more about our services →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-obsidian-light border border-white/10 rounded-2xl p-8 sm:p-12 lg:p-16 text-center relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-electric-cyan/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
        <div class="relative">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            Ready to build something better?
          </h2>
          <p class="text-white/50 max-w-xl mx-auto mb-8">
            Whether you need a strategic review, an automation overhaul, or a ground-up
            infrastructure build, we're here to help.
          </p>
          <a
            href="/contact"
            class="inline-block bg-electric-cyan text-obsidian px-8 py-3 rounded-lg font-semibold hover:bg-electric-cyan-dark transition-colors"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
